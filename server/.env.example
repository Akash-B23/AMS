DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
JWT_SECRET=replace-with-a-long-random-hex-string
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Optional: Bearer token for POST /api/jobs/monthly-invoices and /api/jobs/reminders
CRON_SECRET=

# Email (optional). Prefer SMTP if SMTP_HOST is set; otherwise Resend if RESEND_API_KEY is set.
# When neither is set, deliveries are recorded as skipped (safe for local/dev).
EMAIL_FROM=AMS <noreply@yourdomain.com>

# SMTP (Nodemailer) — e.g. Gmail, Zoho, cPanel, SES SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Resend API (used only when SMTP_HOST is unset)
RESEND_API_KEY=
