DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
JWT_SECRET=replace-with-a-long-random-hex-string
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Optional: Bearer token for POST /api/jobs/monthly-invoices and /api/jobs/reminders
CRON_SECRET=

# Optional: Resend API key for invoice reminders and maintenance alerts.
# When unset, email deliveries are recorded as skipped.
RESEND_API_KEY=
EMAIL_FROM=AMS <noreply@yourdomain.com>
